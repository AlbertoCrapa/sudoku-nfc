{
  "expo": {
    "name": "Sudoku NFC",
    "slug": "sudokunfc",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sudokunfc",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NFCReaderUsageDescription": "This app uses NFC to read and write Sudoku puzzles to NFC tags."
      }
    },
    "android": {
      "versionCode": 2,
      "package": "com.albyeah.sudokunfc",
      "adaptiveIcon": {
        "backgroundColor": "#0d0e14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.NFC"],
      "intentFilters": [
        {
          "action": "android.nfc.action.NDEF_DISCOVERED",
          "category": ["android.intent.category.DEFAULT"],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d0e14",
          "dark": {
            "backgroundColor": "#0d0e14"
          }
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "This app uses NFC to read and write Sudoku puzzles to NFC tags."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fb9014d8-e025-48d1-a29d-664cc5d5af6c"
      }
    },
    "owner": "albyeah"
  }
}
